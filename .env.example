# === Projektroot (neben package.json) — Datei .env oder .env.local anlegen ===
# Steht in .gitignore: Key nirgends committen, nie ins Frontend (kein VITE_*).
# War der Key je öffentlich sichtbar: in OpenAI rotieren, dann nur den neuen Key hier eintragen.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EVAL_SERVER_PORT=8787

# Optional: Frontend zeigt auf anderes Backend (z. B. separates API-Hosting)
# VITE_EVAL_API_URL=https://dein-backend.example.com

# --- Vercel (Dashboard → Settings → Environment Variables) ---
# OPENAI_API_KEY=...   (ohne VITE_-Prefix)
# OPENAI_MODEL=gpt-4o-mini
# Die Route /api/evaluate wird als Serverless Function bereitgestellt; SPA nutzt dieselbe Domain → kein VITE_EVAL_API_URL nötig.
